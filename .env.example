# llm-forge configuration

# Server port
FORGE_PORT=8888

# CORS allowed origins (comma-separated)
# Default: http://localhost:3000,http://localhost:8888
FORGE_CORS_ORIGINS=http://localhost:8888

# API key authentication (true/false)
# When enabled, a default key is generated on first start and printed to console
FORGE_AUTH_ENABLED=false

# OpenAI API key — used for Forge Co-pilot (in-app AI assistant)
# and the landing page AI chat widget
OPENAI_API_KEY=
