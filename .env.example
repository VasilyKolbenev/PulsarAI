# Pulsar AI — Configuration
# Copy to .env and fill in values

# ── Server ───────────────────────────────────────────────
PULSAR_PORT=8888
PULSAR_CORS_ORIGINS=http://localhost:8888
PULSAR_STAND_MODE=dev          # dev | demo (read-only for presentations)

# ── Authentication ───────────────────────────────────────
PULSAR_AUTH_ENABLED=false
PULSAR_JWT_SECRET=              # Required when auth enabled. Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"

# ── Database ─────────────────────────────────────────────
# PULSAR_DB_URL=sqlite:///data/pulsar.db        # Default (SQLite)
# PULSAR_DB_URL=postgresql://user:pass@localhost:5432/pulsar  # PostgreSQL

# ── Job Queue ────────────────────────────────────────────
# PULSAR_REDIS_URL=redis://localhost:6379       # Enables Redis job queue (optional)

# ── Artifact Storage ─────────────────────────────────────
# PULSAR_S3_BUCKET=                              # S3 bucket for model artifacts
# PULSAR_S3_ENDPOINT=                            # Custom S3 endpoint (MinIO etc.)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ── Logging ──────────────────────────────────────────────
PULSAR_LOG_LEVEL=INFO
PULSAR_LOG_FORMAT=console       # console | json (json for production)

# ── External APIs ────────────────────────────────────────
OPENAI_API_KEY=                  # For AI assistant and chat widget
